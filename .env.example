# ============================================================
# VitalOS — Free Dev Stack Environment Variables
# ============================================================

# Supabase (free tier — supabase.com)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini — FREE (aistudio.google.com → Get API Key)
# Used for: OCR of lab report PDFs/images
# Free tier: 1,500 requests/day, 1M tokens/min
VITE_GEMINI_API_KEY=AIza-your-gemini-key
GEMINI_API_KEY=AIza-your-gemini-key

# Groq — FREE (console.groq.com → API Keys)
# Used for: AI health insights + chat (Llama 3.3 70B)
# Free tier: 14,400 requests/day, 30 req/min
VITE_GROQ_API_KEY=gsk_your-groq-key
GROQ_API_KEY=gsk_your-groq-key

# Razorpay — FREE in test mode (dashboard.razorpay.com)
# Use rzp_test_ keys — no real money charged
VITE_RAZORPAY_KEY_ID=rzp_test_your-key-id
RAZORPAY_KEY_SECRET=your-razorpay-secret

# App
VITE_APP_URL=http://localhost:5173
